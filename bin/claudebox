#!/usr/bin/env bash
# claudebox â€” build/run sandboxed Claude Code dev containers. Runs as the host uid/gid (portable);
# all real state lives in host bind mounts, so the box is disposable. Usage: see usage().
set -euo pipefail

REPO="$(cd "$(dirname "$(readlink -f "${BASH_SOURCE[0]}")")/.." && pwd)"  # resolve symlinks (PATH install)
NIX_FLAGS=(--extra-experimental-features 'nix-command flakes')

die() { echo "claudebox: $*" >&2; exit 1; }
usage() { echo "usage: claudebox <build|up|attach|down|status> [project]"; exit "${1:-0}"; }
need() { command -v "$1" >/dev/null || die "missing required tool: $1"; }

profile() {
  local t="$REPO/profiles/$1/profile.toml"
  [ -f "$t" ] || die "no profile at $t (have: $(ls "$REPO/profiles" 2>/dev/null | tr '\n' ' '))"
  printf '%s' "$t"
}
get() { local v; v="$(yq -r "$2" "$1")"; [ "$v" = null ] && v=""; printf '%s' "$v"; }

cmd_build() {
  need nix; need docker
  ( cd "$REPO" && nix "${NIX_FLAGS[@]}" build .#baseImage -o result )
  docker load < "$REPO/result"
}

cmd_up() {
  need docker
  local proj="" attach="" name_override=""
  while [ $# -gt 0 ]; do
    case "$1" in
      -a|--attach) attach=1 ;;
      --name) shift; name_override="${1:?--name needs a value}" ;;
      -*) die "unknown flag: $1 (usage: claudebox up [project] [--name N] [-a|--attach])" ;;
      *) proj="$1" ;;
    esac
    shift
  done

  # No project: box the current directory with working defaults; a profile fills these from its TOML.
  local name="" image="" workspace="" gpu="" claude_bind="" toml=""
  workspace="$PWD"; name="$(basename "$PWD")"
  if [ -n "$proj" ]; then
    need yq
    toml="$(profile "$proj")"
    name="$(get "$toml" '.project.name')"
    image="$(get "$toml" '.project.image')"
    workspace="$(get "$toml" '.workspace.host_path')"
    gpu="$(get "$toml" '.gpu.enabled')"
    claude_bind="$(get "$toml" '.claude.bind')"
  fi
  [ -n "$name_override" ] && name="$name_override"
  [ -n "$image" ] || image="claudebox-base:latest"
  [ -n "$gpu" ] || gpu=false
  [ -n "$claude_bind" ] || claude_bind=true

  if docker container inspect "$name" >/dev/null 2>&1; then
    if [ "$(docker container inspect -f '{{.State.Running}}' "$name")" = true ]; then
      echo ">> '$name' already up. attach: claudebox attach $name"
    else
      docker start "$name" >/dev/null
      echo ">> '$name' resumed. attach: claudebox attach $name"
    fi
    [ -n "$attach" ] && cmd_attach "$name"
    return 0
  fi

  [ -n "$workspace" ] || die "profile $proj: workspace.host_path unset"
  [ -d "$workspace" ] || die "workspace not found: $workspace"
  local state="$HOME/.cache/claudebox/$name"
  mkdir -p "$state/pixi" "$state/cache" "$state/vscode-server/data/Machine"

  # Map the host uid to the `dev` user so VS Code Dev Containers attach resolves a named, writable
  # home (a nameless uid makes it fall back to /root and fail). Bound RO over /etc/{passwd,group}.
  local uid gid; uid="$(id -u)"; gid="$(id -g)"
  printf 'root:x:0:0:root:/root:/bin/bash\ndev:x:%s:%s:dev:/home/dev:/bin/bash\n' "$uid" "$gid" > "$state/passwd"
  printf 'root:x:0:\ndev:x:%s:\n' "$gid" > "$state/group"

  # Declarative VS Code machine settings (all workspaces, any profile) on a persisted .vscode-server,
  # so Python tooling works without manual per-box setup and extensions survive recreation.
  cp "$REPO/assets/vscode-machine-settings.json" "$state/vscode-server/data/Machine/settings.json"

  local args=(run -d
    --name "$name" --hostname "$name" --label claudebox
    --user "$uid:$gid"
    --security-opt no-new-privileges --cap-drop ALL
    -w "$workspace"
    --mount "type=bind,source=$workspace,target=$workspace"
    --mount "type=bind,source=$state/passwd,target=/etc/passwd,readonly"
    --mount "type=bind,source=$state/group,target=/etc/group,readonly"
    --mount "type=bind,source=$state/pixi,target=/home/dev/.pixi"
    --mount "type=bind,source=$state/cache,target=/home/dev/.cache"
    --mount "type=bind,source=$state/vscode-server,target=/home/dev/.vscode-server"
  )
  # Shared ~/.claude dir (memory + auth) + a per-box ~/.claude.json (config), seeded once from the host
  # so claude doesn't warn, kept box-local so host and box never clobber that hot file.
  if [ "$claude_bind" = true ]; then
    [ -f "$state/claude.json" ] || cp "$HOME/.claude.json" "$state/claude.json" 2>/dev/null || echo '{}' > "$state/claude.json"
    args+=(--mount "type=bind,source=$HOME/.claude,target=/home/dev/.claude"
           --mount "type=bind,source=$state/claude.json,target=/home/dev/.claude.json")
  fi

  local ports_str=""
  if [ -n "$toml" ]; then
    while IFS=$'\t' read -r h c; do
      [ -n "$h" ] && args+=(--mount "type=bind,source=$h,target=$c,readonly")
    done < <(yq -r '.mounts[]? | [.host, .container] | @tsv' "$toml")

    while read -r p; do
      if [ -n "$p" ] && [ "$p" != null ]; then
        args+=(-p "0.0.0.0:$p")
        ports_str="${ports_str:+$ports_str, }${p%%:*}"
      fi
    done < <(yq -r '.ports.publish[]?' "$toml")
  fi

  [ "$gpu" = true ] && args+=(--gpus all)
  args+=(-e "CLAUDEBOX_NAME=$name" -e "CLAUDEBOX_WORKSPACE=$workspace"
         -e "CLAUDEBOX_GPU=$gpu" -e "CLAUDEBOX_PORTS=${ports_str:-none}"
         "$image" sleep infinity)

  docker "${args[@]}" >/dev/null
  echo ">> '$name' up. attach: claudebox attach $name"
  if [ -n "$attach" ]; then cmd_attach "$name"; fi
}

cmd_attach() { docker exec -it -e TERM -e COLORTERM "${1:?usage: claudebox attach <project>}" bash; }
cmd_down()   { docker rm -f "${1:?usage: claudebox down <project>}" >/dev/null && echo ">> '$1' removed"; }
cmd_status() { docker ps -a --filter label=claudebox --format 'table {{.Names}}\t{{.Image}}\t{{.Status}}\t{{.Ports}}'; }

case "${1:-}" in
  build)  cmd_build ;;
  up)     shift; cmd_up "$@" ;;
  attach) shift; cmd_attach "$@" ;;
  down)   shift; cmd_down "$@" ;;
  status) cmd_status ;;
  -h|--help|"") usage 0 ;;
  *) usage 1 ;;
esac
