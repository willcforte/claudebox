// Per-project VSCode Dev Containers config. Copy to <repo>/.devcontainer/devcontainer.json.
// Mirror with profiles/<name>/profile.toml. No --cap-drop here (VSCode needs caps for updateRemoteUserUID).
{
  "name": "PROJECT_NAME",
  "image": "claudebox-base:latest",
  "workspaceFolder": "${localWorkspaceFolder}",
  "workspaceMount": "source=${localWorkspaceFolder},target=${localWorkspaceFolder},type=bind",
  "runArgs": ["--gpus", "all"],
  "mounts": [
    "source=${localEnv:HOME}/.claude,target=/home/dev/.claude,type=bind",
    "source=${localEnv:HOME}/.cache/claudebox/PROJECT_NAME/pixi,target=/home/dev/.pixi,type=bind"
  ],
  "initializeCommand": "mkdir -p ${localEnv:HOME}/.cache/claudebox/PROJECT_NAME/pixi",
  "remoteUser": "dev",
  "updateRemoteUserUID": true,
  "customizations": { "vscode": { "extensions": ["anthropic.claude-code"] } }
}
