# Per-project claudebox profile. Copy to profiles/<name>/profile.toml. Read by `claudebox up <name>`.

[project]
name = "PROJECT_NAME"
image = "claudebox-base:latest"

[claude]
bind = true              # bind host ~/.claude RW (shared memory + auth). Default: true.

[workspace]
host_path = "/home/youruser/PROJECT_NAME"   # bound 1:1 so Claude's project-memory slug matches the host

[ports]
publish = []             # e.g. ["9090:9090", "9876:9876"]

[gpu]
passthrough = false      # --gpus all (attach the device). Default: false.
cuda = true              # inject compute,utility (CUDA/torch). Default: true.
graphics = false         # also inject graphics (EGL/GLX headless render, e.g. MuJoCo MUJOCO_GL=egl). Default: false.

[[mounts]]               # RO data, 1:1
host = "/abs/host/path"
container = "/abs/container/path"
