# Nix build outputs
result
result-*

# pixi cache / envs (persisted as a docker volume, never checked in)
.pixi/

# local per-project overrides + secrets
.devcontainer/*.local.*
**/*.local.json
**/*.local.toml
.env
*.secret

# per-project profiles are user/host-specific (absolute paths) — keep them local; ship profiles/example
/profiles/*
!/profiles/example
